{
  "name": "lvls",
  "version": "0.1.0-alpha.59",
  "title": "Go Lavilas Alpha",
  "description": "Standalone alpha channel for the Go implementation of Lavilas, packaged for NV.",
  "homepage": "https://github.com/Perdonus/lavilas-code/tree/nv-go-alpha",
  "aliases": [
    "lvls",
    "lavilas-go",
    "go-lavilas-alpha",
    "lavilas-go-alpha"
  ],
  "dist_tags": [
    "alpha"
  ],
  "readme": "README.md",
  "variants": [
    {
      "id": "lvls-linux-amd64",
      "label": "Linux amd64",
      "os": "linux",
      "default": true,
      "artifact": "dist/lvls-linux-amd64.tar.gz",
      "file_name": "lvls-linux-amd64.tar.gz",
      "install_strategy": "linux-portable-tar"
    },
    {
      "id": "lvls-linux-arm64",
      "label": "Linux arm64",
      "os": "linux",
      "artifact": "dist/lvls-linux-arm64.tar.gz",
      "file_name": "lvls-linux-arm64.tar.gz",
      "install_strategy": "linux-portable-tar"
    },
    {
      "id": "lvls-termux-arm64",
      "label": "Termux ARM64",
      "os": "android",
      "default": true,
      "artifact": "dist/lvls-termux-arm64",
      "file_name": "lvls-termux-arm64",
      "install_strategy": "unix-self-binary",
      "install_root": "$PREFIX/bin",
      "binary_name": "lvls",
      "update_command": "nv i lvls@alpha",
      "metadata": {
        "bootstrapPlatform": "lvls-termux-arm64"
      }
    },
    {
      "id": "lvls-termux-armv7",
      "label": "Termux ARMv7",
      "os": "android",
      "artifact": "dist/lvls-termux-armv7",
      "file_name": "lvls-termux-armv7",
      "install_strategy": "unix-self-binary",
      "install_root": "$PREFIX/bin",
      "binary_name": "lvls",
      "update_command": "nv i lvls@alpha",
      "metadata": {
        "bootstrapPlatform": "lvls-termux-armv7",
        "sourcePlatform": "lvls-linux-armv7"
      }
    },
    {
      "id": "lvls-windows-amd64",
      "label": "Windows amd64",
      "os": "windows",
      "default": true,
      "artifact": "dist/lvls-windows-amd64.exe",
      "file_name": "lvls-windows-amd64.exe",
      "install_strategy": "windows-self-binary",
      "install_root": "%LOCALAPPDATA%/Lvls",
      "binary_name": "lvls.exe"
    }
  ]
}
